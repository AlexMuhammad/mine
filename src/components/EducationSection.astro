---
import type { Lang } from "../i18n/translations";
import { t } from "../i18n/translations";
import { educations } from "../i18n/data";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="education" class="mb-20">
  <SectionHeader title={t(lang, "section.education")} icon="graduation-cap" />

  <div class="space-y-4">
    {educations.map((edu) => (
      <div class="rounded-sm border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-6">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
          <div>
            <h3 class="text-base font-primary font-bold text-gray-900 dark:text-white uppercase tracking-wide">
              {edu.degree[lang]}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 font-secondary">
              {edu.school} &middot; {edu.location}
            </p>
            {edu.description && (
              <p class="text-sm text-gray-600 dark:text-gray-400 font-secondary mt-2">
                {edu.description[lang]}
              </p>
            )}
          </div>
          <span class="text-xs font-medium text-primary-500 bg-primary-500/10 px-3 py-1 rounded-sm whitespace-nowrap self-start">
            {edu.startDate} — {edu.endDate}
          </span>
        </div>
      </div>
    ))}
  </div>
</section>
