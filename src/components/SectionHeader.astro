---
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<div class="flex items-center gap-4 mb-8" id={id}>
  <h2 class="text-sm font-primary font-bold uppercase tracking-[0.2em] text-gray-900 dark:text-white whitespace-nowrap">
    <slot name="icon" />
    {title}
  </h2>
  <div class="flex-1 border-t border-dashed border-gray-300 dark:border-neutral-700"></div>
</div>
