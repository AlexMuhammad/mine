---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Alex — Developer & Creator">
  <main class="flex items-center justify-center min-h-screen px-6">
    <div class="text-center">
      <h1 class="text-5xl md:text-7xl font-primary tracking-tight mb-4">
        Hello, I'm Alex
      </h1>
      <p class="text-lg md:text-xl text-gray-600 font-secondary max-w-xl mx-auto">
        Developer, creator, and problem solver. Welcome to my portfolio.
      </p>
    </div>
  </main>
</Layout>
