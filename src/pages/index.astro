---
import Layout from "../layouts/Layout.astro";
import FloatingNav from "../components/FloatingNav.astro";
import HeroSection from "../components/HeroSection.astro";
import DescriptionSection from "../components/DescriptionSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import EducationSection from "../components/EducationSection.astro";
import AchievementsSection from "../components/AchievementsSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";

const lang = "en" as const;
---

<Layout
  title="Alex — Developer & Creator"
  description="Portfolio of Alex — A passionate developer crafting modern web applications with clean code and thoughtful design."
  lang={lang}
>
  <FloatingNav lang={lang} />

  <main>
    <div class="max-w-4xl mx-auto px-6 py-12 pb-24">
      <HeroSection lang={lang} />
      <DescriptionSection lang={lang} />
      <SkillsSection lang={lang} />
      <ExperienceSection lang={lang} />
      <EducationSection lang={lang} />
      <AchievementsSection lang={lang} />
      <!-- <ProjectsSection lang={lang} /> -->

      <footer class="text-center text-xs text-gray-400 dark:text-gray-600 pt-8 border-t border-gray-200 dark:border-neutral-800">
        <p>&copy; 2026 Alex. Built with Astro & Tailwind CSS.</p>
      </footer>
    </div>
  </main>
</Layout>
